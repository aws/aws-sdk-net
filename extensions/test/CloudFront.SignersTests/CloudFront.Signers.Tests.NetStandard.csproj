		<PackageReference Include="MSTest.TestFramework" Version="3.5.0" />
	</ItemGroup>
	<ItemGroup>
	  <None Update="EmbeddedResource\sample.rsa.private.key.txt">
	    <CopyToOutputDirectory>Always</CopyToOutputDirectory>
	  </None>
	</ItemGroup>
