    <file src=".\bin\Release\net8.0\AWSSDK.Extensions.NETCore.Setup.dll" target="lib\net8.0" />
    <file src=".\bin\Release\net8.0\AWSSDK.Extensions.NETCore.Setup.pdb" target="lib\net8.0" />
  </files>
</package>