    <ProjectReference Include="../../src/Services/SecurityToken/AWSSDK.SecurityToken.NetStandard.csproj" />
    <ProjectReference Include="../../src/Services/CognitoSync/AWSSDK.CognitoSync.NetStandard.csproj" />
