<Project Sdk="Microsoft.NET.Sdk">
  <!-- This project file is generated. Do not edit this file directly. -->
  <PropertyGroup>
   <RunAnalyzersDuringBuild Condition="'$(RunAnalyzersDuringBuild)'==''">true</RunAnalyzersDuringBuild>
    <TargetFrameworks>$(SdkNetFrameworkTargets)</TargetFrameworks>
    <DefineConstants>$(DefineConstants);</DefineConstants>
    <!-- AWS_ASYNC_ENUMERABLES_API gates the async-enumerable/paginator APIs, which are unavailable on
         .NET Framework. The identifier-based condition covers every non-.NETFramework target
         (netstandard2.0, netcoreapp3.1, net8.0, and any future target) without hardcoding TFM names.
         On .NET Framework the condition is false so the constant is not defined. -->
    <DefineConstants Condition="$([MSBuild]::GetTargetFrameworkIdentifier('$(TargetFramework)')) != '.NETFramework'">$(DefineConstants);AWS_ASYNC_ENUMERABLES_API</DefineConstants>
    <DebugType>portable</DebugType>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <AssemblyName>AWSSDK.UnitTests.NetFramework</AssemblyName>
    <PackageId>AWSSDK.UnitTests.NetFramework</PackageId>

    <GenerateAssemblyTitleAttribute>false</GenerateAssemblyTitleAttribute>
    <GenerateAssemblyConfigurationAttribute>false</GenerateAssemblyConfigurationAttribute>
    <GenerateAssemblyProductAttribute>false</GenerateAssemblyProductAttribute>
    <GenerateAssemblyCompanyAttribute>false</GenerateAssemblyCompanyAttribute>
    <GenerateAssemblyCopyrightAttribute>false</GenerateAssemblyCopyrightAttribute>
    <GenerateAssemblyVersionAttribute>false</GenerateAssemblyVersionAttribute>
    <GenerateAssemblyFileVersionAttribute>false</GenerateAssemblyFileVersionAttribute>
    <GenerateAssemblyDescriptionAttribute>false</GenerateAssemblyDescriptionAttribute>
    <SignAssembly>true</SignAssembly>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>

    <NoWarn>CS1591,CS0612,CS0618</NoWarn>
  </PropertyGroup>
  <Choose>
    <When Condition=" '$(AWSKeyFile)' == '' ">
      <PropertyGroup>
        <AssemblyOriginatorKeyFile>../../awssdk.dll.snk</AssemblyOriginatorKeyFile>
      </PropertyGroup>
    </When>
    <Otherwise>
      <PropertyGroup>
        <AssemblyOriginatorKeyFile>$(AWSKeyFile)</AssemblyOriginatorKeyFile>
      </PropertyGroup>
    </Otherwise>
  </Choose>

  <ItemGroup>
    <Compile Include="../Services/*/UnitTests/**/*.cs"/>
  </ItemGroup>
  <ItemGroup>
    <Compile Remove="**/obj/**"/>
    <None Remove="**/obj/**" />
    <Compile Remove="**/_netstandard/**"/>
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../../src/Core/AWSSDK.Core.NetFramework.csproj"/>
    <ProjectReference Include="../Common/AWSSDK.CommonTest.csproj"/>
    <ProjectReference Include="../../../generator/ServiceClientGeneratorLib/ServiceClientGeneratorLib.csproj"/>
    <ProjectReference Include="../../../extensions/src/AWSSDK.Extensions.CrtIntegration/AWSSDK.Extensions.CrtIntegration.NetFramework.csproj"/>
    <ProjectReference Include="../../src/Services/*/*.NetFramework.csproj"/>
    <ProjectReference Include="../../test/Services/*/*.NetFramework.csproj"/>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Moq" Version="4.18.4"/>
    <PackageReference Include="MSTest.TestAdapter" Version="3.11.1"/>
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.13.0"/>
    <PackageReference Include="MSTest.TestFramework" Version="3.11.1"/>
    <PackageReference Include="AutoFixture" Version="4.18.1"/>
    <PackageReference Include="AutoFixture.AutoMoq" Version="4.18.1"/>
  </ItemGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'net472'">
    <Reference Include="System.Configuration"/>
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="Custom\Runtime\TestResponses\*.txt"/>
    <EmbeddedResource Include="Custom\Runtime\EventStreams\test_vectors\*"/>
    <EmbeddedResource Include="Custom\Runtime\TestEndpoints\*.json"/>
    <EmbeddedResource Include="Custom\TestTools\ComparerTest.json"/>
    <EmbeddedResource Include="..\Services\S3\UnitTests\Custom\EmbeddedResource\*"/>
  </ItemGroup>

</Project>