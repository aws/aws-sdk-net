<!--
  This project is manually maintained (not generated).
  It contains Core runtime unit tests that are included in every service solution,
  so developers can run Core tests alongside service-specific tests.
  Only reference services that are acceptable as dependencies in all service solutions:
  S3, SecurityToken, SimpleNotificationService, SQS, and DynamoDBv2.
-->
<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
   <RunAnalyzersDuringBuild Condition="'$(RunAnalyzersDuringBuild)'==''">true</RunAnalyzersDuringBuild>
    <TargetFrameworks>$(SdkTestTargets)</TargetFrameworks>
    <DefineConstants>$(DefineConstants);</DefineConstants>
    <!-- AWS_ASYNC_ENUMERABLES_API gates the async-enumerable/paginator APIs, which are unavailable on
         .NET Framework. The identifier-based condition covers every non-.NETFramework target without
         hardcoding TFM names. On .NET Framework the condition is false so the constant is not defined. -->
    <DefineConstants Condition="$([MSBuild]::GetTargetFrameworkIdentifier('$(TargetFramework)')) != '.NETFramework'">$(DefineConstants);AWS_ASYNC_ENUMERABLES_API</DefineConstants>
    <DebugType>portable</DebugType>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <AssemblyName>AWSSDK.UnitTests.Core</AssemblyName>
    <PackageId>AWSSDK.UnitTests.Core</PackageId>

    <GenerateAssemblyTitleAttribute>false</GenerateAssemblyTitleAttribute>
    <GenerateAssemblyConfigurationAttribute>false</GenerateAssemblyConfigurationAttribute>
    <GenerateAssemblyProductAttribute>false</GenerateAssemblyProductAttribute>
    <GenerateAssemblyCompanyAttribute>false</GenerateAssemblyCompanyAttribute>
    <GenerateAssemblyCopyrightAttribute>false</GenerateAssemblyCopyrightAttribute>
    <GenerateAssemblyVersionAttribute>false</GenerateAssemblyVersionAttribute>
    <GenerateAssemblyFileVersionAttribute>false</GenerateAssemblyFileVersionAttribute>
    <GenerateAssemblyDescriptionAttribute>false</GenerateAssemblyDescriptionAttribute>
    <SignAssembly>true</SignAssembly>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>

    <!-- SuppressTfmSupportBuildWarnings and GenerateBindingRedirectsOutputType are inherited from
         sdk/Directory.Build.props (the latter conditioned on the .NETFramework target identifier). -->
    <NoWarn>CS1591,CS0612,CS0618</NoWarn>
  </PropertyGroup>
  <PropertyGroup>
    <LangVersion>11.0</LangVersion>
  </PropertyGroup>
  <Choose>
    <When Condition=" '$(AWSKeyFile)' == '' ">
      <PropertyGroup>
        <AssemblyOriginatorKeyFile>../../awssdk.dll.snk</AssemblyOriginatorKeyFile>
      </PropertyGroup>
    </When>
    <Otherwise>
      <PropertyGroup>
        <AssemblyOriginatorKeyFile>$(AWSKeyFile)</AssemblyOriginatorKeyFile>
      </PropertyGroup>
    </Otherwise>
  </Choose>

  <ItemGroup>
    <Compile Remove="**/obj/**"/>
    <None Remove="**/obj/**" />
  </ItemGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'net472'">
    <Compile Remove="**/_netstandard/**"/>
  </ItemGroup>
  <ItemGroup Condition="'$(TargetFramework)' != 'net472'">
    <Compile Remove="**/_bcl/**"/>
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../Common/AWSSDK.CommonTest.csproj"/>
    <ProjectReference Include="../../../generator/ServiceClientGeneratorLib/ServiceClientGeneratorLib.csproj"/>
  </ItemGroup>

  <ItemGroup Condition="'$(TargetFramework)' != 'net472'">
    <ProjectReference Include="../../src/Core/AWSSDK.Core.NetStandard.csproj"/>
    <ProjectReference Include="../../src/Services/S3/AWSSDK.S3.NetStandard.csproj"/>
    <ProjectReference Include="../../src/Services/SecurityToken/AWSSDK.SecurityToken.NetStandard.csproj"/>
    <ProjectReference Include="../../src/Services/SimpleNotificationService/AWSSDK.SimpleNotificationService.NetStandard.csproj"/>
    <ProjectReference Include="../../src/Services/SQS/AWSSDK.SQS.NetStandard.csproj"/>
    <ProjectReference Include="../../src/Services/DynamoDBv2/AWSSDK.DynamoDBv2.NetStandard.csproj"/>
    <ProjectReference Include="../../../extensions/src/AWSSDK.Extensions.CrtIntegration/AWSSDK.Extensions.CrtIntegration.NetStandard.csproj"/>
  </ItemGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'net472'">
    <ProjectReference Include="../../src/Core/AWSSDK.Core.NetFramework.csproj"/>
    <ProjectReference Include="../../src/Services/S3/AWSSDK.S3.NetFramework.csproj"/>
    <ProjectReference Include="../../src/Services/SecurityToken/AWSSDK.SecurityToken.NetFramework.csproj"/>
    <ProjectReference Include="../../src/Services/SimpleNotificationService/AWSSDK.SimpleNotificationService.NetFramework.csproj"/>
    <ProjectReference Include="../../src/Services/SQS/AWSSDK.SQS.NetFramework.csproj"/>
    <ProjectReference Include="../../src/Services/DynamoDBv2/AWSSDK.DynamoDBv2.NetFramework.csproj"/>
    <ProjectReference Include="../../../extensions/src/AWSSDK.Extensions.CrtIntegration/AWSSDK.Extensions.CrtIntegration.NetFramework.csproj"/>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Moq" Version="4.18.4"/>
    <PackageReference Include="MSTest.TestAdapter" Version="3.11.1"/>
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.13.0"/>
    <PackageReference Include="MSTest.TestFramework" Version="3.11.1"/>
    <PackageReference Include="AutoFixture" Version="4.18.1"/>
    <PackageReference Include="AutoFixture.AutoMoq" Version="4.18.1"/>
  </ItemGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'net472'">
    <Reference Include="System.Configuration"/>
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="Custom\Runtime\TestResponses\*.txt"/>
    <EmbeddedResource Include="Custom\Runtime\EventStreams\test_vectors\*"/>
    <EmbeddedResource Include="Custom\Runtime\TestEndpoints\*.json"/>
    <EmbeddedResource Include="Custom\TestTools\ComparerTest.json"/>
  </ItemGroup>

</Project>
