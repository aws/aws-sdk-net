<#
        }
        else if (member.Shape.IsDouble)
        {
#>
                unmarshalledObject.<#=member.PropertyName#> = context.ResponseData.GetEventStreamHeader("<#=member.ModeledName#>").AsDouble();
<#
        }
#>
            }
<#
    }
