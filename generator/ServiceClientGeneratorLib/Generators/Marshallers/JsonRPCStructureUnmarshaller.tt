<#
    this.AddStructureSingletonMethod();
#>
    }
}

<#
    void ProcessEventHeader(Member member)
    {
#>
            if (context.ResponseData.IsEventHeaderPresent("<#=member.ModeledName#>"))
            {
<#
        if (member.Shape.IsBoolean)
        {
#>
                unmarshalledObject.<#=member.PropertyName#> = context.ResponseData.GetEventStreamHeader("<#=member.ModeledName#>").AsBool();
<#
        }
        else if (member.Shape.IsInt)
        {
#>
                unmarshalledObject.<#=member.PropertyName#> = context.ResponseData.GetEventStreamHeader("<#=member.ModeledName#>").AsInt();
<#
        }
        else if (member.Shape.IsLong)
        {
#>
                unmarshalledObject.<#=member.PropertyName#> = context.ResponseData.GetEventStreamHeader("<#=member.ModeledName#>").AsLong();
<#
        }
        else if (member.Shape.IsString)
        {
#>
                unmarshalledObject.<#=member.PropertyName#> = context.ResponseData.GetEventStreamHeader("<#=member.ModeledName#>").AsString();
<#
        }
        else if (member.Shape.IsTimeStamp)
        {
#>
                unmarshalledObject.<#=member.PropertyName#> = context.ResponseData.GetEventStreamHeader("<#=member.ModeledName#>").AsTimestamp();
<#
        }
        else if (member.Shape.IsMemoryStream)
        {
#>
                var s = context.ResponseData.GetEventStreamHeader("<#=member.ModeledName#>");
